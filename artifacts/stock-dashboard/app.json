{
  "expo": {
    "name": "스윙의 정석",
    "slug": "stock-dashboard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stock-dashboard",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/aee91b67-b0e2-4588-b8c3-69f1c3852b2b"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.swingjeongseok.app",
      "infoPlist": {
        "UIBackgroundModes": ["fetch"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.swingjeongseok.app"
    },
    "web": {
      "favicon": "./assets/images/caricature-favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "aee91b67-b0e2-4588-b8c3-69f1c3852b2b"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0064FF",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "포트폴리오 스크린샷을 불러오기 위해 사진 라이브러리 접근이 필요합니다.",
          "cameraPermission": "포트폴리오 스크린샷을 촬영하기 위해 카메라 접근이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
